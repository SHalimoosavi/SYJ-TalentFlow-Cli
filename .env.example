# ─────────────────────────────────────────────
# TalentFlow CLI — environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file.
# ─────────────────────────────────────────────

# Which AI provider to use: anthropic | openai | openrouter
AI_PROVIDER=anthropic

# Model name. Leave blank to use the provider's sensible default.
# Examples: claude-sonnet-4-6 (Anthropic), gpt-4o-mini (OpenAI), openrouter/auto (OpenRouter)
MODEL=

# Sampling temperature for AI scoring/generation (0.0 - 1.0)
TEMPERATURE=0.3

# ── API keys — only the one matching AI_PROVIDER is required ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ── Optional: scoring weights (must be non-negative; auto-normalized) ──
TALENTFLOW_SKILLS_WEIGHT=0.5
TALENTFLOW_EXPERIENCE_WEIGHT=0.3
TALENTFLOW_KEYWORD_WEIGHT=0.2

# ── Optional: ranking thresholds (percent) ──
TALENTFLOW_SHORTLIST_THRESHOLD=75
TALENTFLOW_REVIEW_THRESHOLD=50

# ── Optional: default directories ──
TALENTFLOW_RESUMES_DIR=resumes
TALENTFLOW_JOBS_DIR=jobs
TALENTFLOW_OUTPUT_DIR=output

# ── Optional: globally disable AI features (true/false) ──
TALENTFLOW_USE_AI=true
